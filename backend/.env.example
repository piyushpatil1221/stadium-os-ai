# App
APP_NAME=StadiumOS AI
APP_ENV=development
DEBUG=true

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/stadiumos
# Fallback SQLite (uncomment for local dev)
# DATABASE_URL=sqlite:///./stadiumos.db

# JWT
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI (optional - will use mock if not set)
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
